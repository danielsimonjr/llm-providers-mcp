# GitHub Actions workflow — deferred from v0.1.0 release.
#
# To activate:
#   1. Run:  gh auth refresh -h github.com -s workflow
#      (adds the `workflow` OAuth scope — GitHub requires it to push
#       files under .github/workflows/ via an OAuth app)
#   2. Move this file: git mv docs/ci.yml.example .github/workflows/ci.yml
#   3. Commit and push.
#
# The workflow runs ruff + pytest (unit tests only, integration skipped)
# on Linux and Windows, Python 3.10 through 3.13.

name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: read

jobs:
  lint:
    name: ruff
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v3
        with:
          enable-cache: true
      - name: Install ruff
        run: uv pip install --system ruff
      - name: ruff check
        run: ruff check .
      - name: ruff format --check
        run: ruff format --check .

  test:
    name: pytest (${{ matrix.os }}, Python ${{ matrix.python-version }})
    runs-on: ${{ matrix.os }}
    strategy:
      fail-fast: false
      matrix:
        os: [ubuntu-latest, windows-latest]
        python-version: ['3.10', '3.11', '3.12', '3.13']
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v3
        with:
          enable-cache: true
      - name: Set up Python ${{ matrix.python-version }}
        run: uv python install ${{ matrix.python-version }}
      - name: Create venv
        run: uv venv --python ${{ matrix.python-version }}
      - name: Install with all extras
        run: uv pip install -e ".[openai,gemini,dev]"
      - name: Run unit tests (no network, no keys required)
        run: uv run pytest -m "not integration" -v
